# Diamond Vault MCP Server - Docker Integration
# Multi-stage build with CUDA support for Claude Desktop

# Stage 1: Build with CUDA
FROM nvidia/cuda:12.2.0-runtime-ubuntu22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /build

RUN apt-get update && apt-get install -y \
    python3.11 python3.11-dev python3-pip \
    build-essential gcc make curl jq \
    && rm -rf /var/lib/apt/lists/*

RUN python3.11 -m pip install --no-cache-dir --upgrade pip

# Install dependencies
COPY genesis-q-mem/requirements.txt ./requirements-qmem.txt
COPY requirements.txt ./requirements-root.txt 2>/dev/null || echo "# No root requirements" > ./requirements-root.txt

RUN python3.11 -m pip install --no-cache-dir \
    flask cryptography requests numpy cupy-cuda12x jax[cuda12_pip] \
    -r requirements-qmem.txt || true

# Stage 2: Runtime
FROM nvidia/cuda:12.2.0-runtime-ubuntu22.04

LABEL maintainer="Yennefer <yennefer@genesisconductor.io>"
LABEL description="Diamond Vault MCP Server - Quantum GPU Operations"
LABEL version="1.0.0"

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /app

RUN apt-get update && apt-get install -y \
    python3.11 python3-pip curl jq \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3.11 /usr/bin/python3

# Copy Python packages from builder
COPY --from=builder /usr/local/lib/python3.11/dist-packages /usr/local/lib/python3.11/dist-packages

# Copy MCP server and scripts
COPY scripts/diamond_vault_mcp_server.py ./mcp_server.py
COPY scripts/diamond_vault_crypto.py ./scripts/
COPY scripts/dual_bridge_router.py ./scripts/
COPY scripts/docker_mcp_integration.py ./scripts/

# Create data directories
RUN mkdir -p /data/diamond_vault/keys \
    /data/diamond_vault/manifests \
    /data/kg_storage \
    /data/logs

# Environment
ENV PYTHONUNBUFFERED=1
ENV VAULT_DIR=/data/diamond_vault
ENV JAX_PLATFORM_NAME=gpu
ENV CUDA_VISIBLE_DEVICES=0
ENV OFFLOAD_MODE=always
ENV DUAL_BRIDGE_ENABLED=true

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD python3 -c "import sys; sys.exit(0)"

# MCP Server runs on stdio (not HTTP)
CMD ["python3", "/app/mcp_server.py"]
